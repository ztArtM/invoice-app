# Example environment variables for local CVR lookup (server: npm run dev:api).
# Copy values into your shell, or use a local env file with a loader you prefer.
# Node does not load this file automatically unless you use dotenv or `node --env-file`.

# --- CVRAPI v6 (https://cvrapi.dk/api) ---
# Identify your integration (ASCII only; avoid em dashes / smart quotes in the value).
CVRAPI_USER_AGENT=YourCompany - invoice-app - your.email@example.com

# Optional: overrides default token query value `YOUR_TOKEN` (same as browser URL examples).
# If unset, requests use token=YOUR_TOKEN literally. Only `search` uses the user's CVR.
# CVRAPI_TOKEN=your_real_token_from_cvrapi

# Optional: pin API version if needed.
# CVRAPI_VERSION=

# Dev-only: log request URL (token redacted), HTTP status, and API error codes (QUOTA_EXCEEDED, etc.).
# PowerShell: $env:DEBUG_CVRAPI='1'; npm run dev:api
# bash:        DEBUG_CVRAPI=1 npm run dev:api
DEBUG_CVRAPI=

# Optional: enable a local demo row for CVR=12345678 (avoids fake data unless explicitly enabled).
# CVRAPI_DEMO=1

# Port for POST /api/company-lookup (must match vite.config.ts proxy target, default 8787).
CVR_DEV_API_PORT=8787

# --- Vercel (serverless /api/company-lookup) ---
# Optional: restrict CORS to your site origin, e.g. https://your-app.vercel.app
# Same-origin deploys usually do not need this. Default is *.
# CORS_ALLOW_ORIGIN=https://your-domain.com

# --- Tally feedback (optional) ---
# Full share URLs or bare form ids. English is used when the UI language is English;
# Danish uses DA when set, else falls back to EN.
# Create matching hidden fields in Tally: lang, route, invoiceId, itemCount, notesLength,
# printMode, screenWidth, screenHeight, appVersion (see src/utils/tallyFeedback.ts).
# VITE_TALLY_FEEDBACK_FORM_EN=https://tally.so/r/XxY4d4
# VITE_TALLY_FEEDBACK_FORM_DA=https://tally.so/r/ODY7qK
# Optional app version string shown in feedback context (defaults to 0.0.0).
# VITE_APP_VERSION=1.0.0

# --- SEO (build + runtime) ---
# Production origin, no trailing slash. Used for canonical URLs, Open Graph, JSON-LD, sitemap, and robots.txt.
# VITE_SITE_URL=https://your-domain.com
# Optional: absolute URL to a social preview image (PNG/JPG/WebP, ~1200×630). If unset, cards use title/description only.
# VITE_OG_IMAGE_URL=https://your-domain.com/og-image.png
# Optional: Twitter/X handle without @ for twitter:site
# VITE_TWITTER_SITE=yourhandle
